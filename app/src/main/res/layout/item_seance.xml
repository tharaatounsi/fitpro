<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#1A1A24"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne 1 : Emoji + Nom + Calories + Menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Emoji -->
            <TextView
                android:id="@+id/tvSeanceEmoji"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:textSize="28sp"
                android:background="@drawable/bg_emoji"
                android:text="💪"/>

            <!-- Nom + Sets/Reps -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvSeanceNom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bench Press"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSeanceSetsReps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 sets × 10 reps"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Calories -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvSeanceCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="180"
                    android:textColor="#FF4D6D"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="kcal"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- Menu ⋮ -->
            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="⋮"
                android:textSize="20sp"
                android:textColor="#AAAAAA"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Ligne 2 : Cercles sets -->
        <LinearLayout
            android:id="@+id/layoutSets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sets : "
                android:textColor="#888888"
                android:textSize="13sp"/>

            <!-- Les cercles seront ajoutés dynamiquement dans le code -->
            <LinearLayout
                android:id="@+id/layoutCercles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"/>

        </LinearLayout>

        <!-- Ligne 3 : Barre de progression -->
        <ProgressBar
            android:id="@+id/progressSets"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="10dp"
            android:progressTint="#06D6A0"
            android:progressBackgroundTint="#2A2A3A"
            android:max="100"
            android:progress="0"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
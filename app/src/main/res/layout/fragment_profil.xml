<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Avatar -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="👤"
            android:textSize="40sp"
            android:gravity="center"
            android:background="@drawable/bg_avatar"
            android:layout_marginBottom="16dp"/>

        <!-- Nom -->
        <TextView
            android:id="@+id/tvProfilNom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <!-- Email -->
        <TextView
            android:id="@+id/tvProfilEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- Card abonnement -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mon abonnement"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvProfilStatut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvProfilExpiration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expire le : --"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Voir publications -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvVoirPublications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📢 Voir les publications"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:padding="20dp"/>

        </androidx.cardview.widget.CardView>

        <!-- Voir événements -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvVoirEvenements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📅 Voir les événements"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:padding="20dp"/>

        </androidx.cardview.widget.CardView>

        <!-- Bouton déconnexion -->
        <Button
            android:id="@+id/btnDeconnexion"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Se déconnecter"
            android:backgroundTint="#FF4D6D"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>

</ScrollView>